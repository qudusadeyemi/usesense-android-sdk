<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/usesense_dot_glow" />
            <size android:width="28dp" android:height="28dp" />
        </shape>
    </item>
    <!-- Inner dot -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="@color/usesense_dot_color" />
        </shape>
    </item>
</layer-list>
