<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================================ -->
    <!-- UseSense Brand Manual v3.0 — Theme System                    -->
    <!-- Typography: Outfit (display), DM Sans (body), monospace (code) -->
    <!-- Colors: DeepSense Blue primary, warm neutrals                 -->
    <!-- Border radius: sm=6, md=10, lg=14, xl=20                     -->
    <!-- ============================================================ -->

    <!-- Full-screen container with edge-to-edge layout -->
    <style name="Theme.UseSense" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/usesense_primary</item>
        <item name="colorPrimaryVariant">@color/usesense_primary_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:windowBackground">@color/usesense_background</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- ═══ Buttons ═══ -->
    <!-- Brand manual: 44px default, 10px (md) radius -->

    <!-- Brand / Primary Button: DeepSense Blue bg, white text -->
    <style name="UseSense.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">44dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">10dp</item>
        <item name="backgroundTint">@color/usesense_primary</item>
    </style>

    <!-- Secondary Button: n0 bg, n2 border -->
    <style name="UseSense.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">44dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/usesense_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">10dp</item>
        <item name="strokeColor">@color/usesense_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Base Styles -->
    <style name="UseSense" />
    <style name="UseSense.Text" />

    <!-- ═══ Text Styles ═══ -->
    <!-- Display: Outfit → sans-serif-medium (bold, tight tracking) -->
    <!-- Body: DM Sans → sans-serif -->
    <!-- Code: JetBrains Mono → monospace -->

    <!-- Screen Title: Outfit 700, -0.03em tracking -->
    <style name="UseSense.Text.Title">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/usesense_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAlignment">center</item>
        <item name="android:letterSpacing">-0.03</item>
    </style>

    <!-- Subtitle: DM Sans 400, 1.6 line-height -->
    <style name="UseSense.Text.Subtitle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/usesense_text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textAlignment">center</item>
        <item name="android:lineSpacingMultiplier">1.6</item>
    </style>

    <!-- Phase Badge: mono-style, uppercase, tight -->
    <style name="UseSense.Text.Badge">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <!-- Countdown: Display weight, tight tracking -->
    <style name="UseSense.Text.Countdown">
        <item name="android:textSize">60sp</item>
        <item name="android:textColor">@color/usesense_countdown_number</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">-0.04</item>
    </style>

    <!-- Instructions Title: Outfit 700 -->
    <style name="UseSense.Text.InstructionsTitle">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/usesense_instructions_title</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAlignment">center</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <!-- Instructions Body: DM Sans 400, 1.6 line-height -->
    <style name="UseSense.Text.InstructionsBody">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/usesense_instructions_body</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textAlignment">center</item>
        <item name="android:lineSpacingMultiplier">1.6</item>
    </style>

    <!-- Caption: DM Sans, muted (n4) -->
    <style name="UseSense.Text.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/usesense_caption_muted</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textAlignment">center</item>
        <item name="android:lineSpacingMultiplier">1.6</item>
    </style>

    <!-- Monospace: for session IDs, API keys, scores -->
    <style name="UseSense.Text.Mono">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/usesense_primary</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>
