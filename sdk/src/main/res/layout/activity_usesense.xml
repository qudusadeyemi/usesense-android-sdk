<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/usesense_background">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:scaleType="fillCenter"
        app:implementationMode="compatible" />

    <!-- Challenge Overlay (dot, arrows, phrase text) -->
    <FrameLayout
        android:id="@+id/challengeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Follow-the-dot -->
        <View
            android:id="@+id/dotView"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/usesense_dot"
            android:elevation="8dp"
            android:visibility="gone" />

        <!-- Head turn instruction -->
        <TextView
            android:id="@+id/directionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|top"
            android:layout_marginTop="80dp"
            android:textColor="@color/usesense_text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:shadowColor="#AA000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:visibility="gone" />

        <!-- Speak phrase -->
        <LinearLayout
            android:id="@+id/speakPhraseLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/speakLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/usesense_speak_now"
                android:textColor="@color/usesense_text_secondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/phraseText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/usesense_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/recordingIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/usesense_recording"
                android:textColor="@color/usesense_error"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Progress bar (time remaining) -->
        <ProgressBar
            android:id="@+id/challengeProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_gravity="bottom"
            android:progressTint="@color/usesense_primary"
            android:progressBackgroundTint="#33FFFFFF" />
    </FrameLayout>

    <!-- Instructions Screen -->
    <LinearLayout
        android:id="@+id/instructionsLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="@color/usesense_background"
        android:visibility="gone">

        <TextView
            android:id="@+id/instructionsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/usesense_title"
            android:textColor="@color/usesense_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/instructionsBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="@color/usesense_text_secondary"
            android:textSize="16sp"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:text="@string/usesense_start_button"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/usesense_primary" />
    </LinearLayout>

    <!-- Processing / Loading Screen -->
    <LinearLayout
        android:id="@+id/processingLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="@color/usesense_background"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/processingSpinner"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="@color/usesense_primary" />

        <TextView
            android:id="@+id/processingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/usesense_uploading"
            android:textColor="@color/usesense_text_primary"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Result Screen -->
    <LinearLayout
        android:id="@+id/resultLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="@color/usesense_background"
        android:visibility="gone">

        <TextView
            android:id="@+id/resultIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:gravity="center"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/resultText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="@color/usesense_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/resultDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/usesense_text_secondary"
            android:textSize="14sp"
            android:textAlignment="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/doneButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:text="@string/usesense_done"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/usesense_primary" />
    </LinearLayout>

    <!-- Cancel button (floating) -->
    <ImageButton
        android:id="@+id/cancelButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/usesense_cancel"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="@color/usesense_text_primary"
        android:elevation="4dp" />

</FrameLayout>
