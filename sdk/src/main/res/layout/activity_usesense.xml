<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/usesense_background">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:scaleType="fillCenter"
        app:implementationMode="compatible" />

    <!-- Challenge Overlay (dot, arrows, phrase text) -->
    <FrameLayout
        android:id="@+id/challengeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Subtle baseline oval reminder (non-interactive) -->
        <com.usesense.sdk.ui.BaselineOvalView
            android:id="@+id/baselineOvalView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Follow-the-dot (indigo) -->
        <View
            android:id="@+id/dotView"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/usesense_dot"
            android:elevation="8dp"
            android:visibility="gone" />

        <!-- Head turn instruction -->
        <TextView
            android:id="@+id/directionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|top"
            android:layout_marginTop="80dp"
            android:textColor="@color/usesense_text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:shadowColor="#AA000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:visibility="gone" />

        <!-- Head turn direction circle (indigo gradient, drawn programmatically) -->
        <FrameLayout
            android:id="@+id/directionCircle"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center"
            android:elevation="12dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/directionArrow"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:tint="@color/usesense_text_primary" />
        </FrameLayout>

        <!-- Speak phrase -->
        <LinearLayout
            android:id="@+id/speakPhraseLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/speakLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/usesense_speak_now"
                android:textColor="@color/usesense_text_secondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/phraseText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/usesense_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/recordingIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/usesense_recording"
                android:textColor="@color/usesense_error"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Phase badge (baseline / challenge label) -->
        <TextView
            android:id="@+id/phaseBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@drawable/usesense_badge_bg"
            android:textColor="@color/usesense_text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Progress bar (time remaining, indigo) -->
        <ProgressBar
            android:id="@+id/challengeProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_gravity="bottom"
            android:progressTint="@color/usesense_indigo_500"
            android:progressBackgroundTint="#33FFFFFF" />
    </FrameLayout>

    <!-- Face Guide Overlay (v1.17.5+) -->
    <FrameLayout
        android:id="@+id/faceGuideOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Semi-transparent bg with oval cutout and pulsing dashed border -->
        <com.usesense.sdk.ui.FaceGuideOvalView
            android:id="@+id/faceGuideOvalView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Top label -->
        <TextView
            android:id="@+id/faceGuideLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|top"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:background="@drawable/usesense_pill_bg"
            android:text="@string/usesense_face_guide_label"
            android:textColor="@color/usesense_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Bottom ready button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/faceGuideReadyButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="48dp"
            android:paddingHorizontal="32dp"
            android:text="@string/usesense_face_guide_ready"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/usesense_indigo_600"
            android:elevation="8dp" />
    </FrameLayout>

    <!-- Countdown Overlay (v1.17.5+) -->
    <FrameLayout
        android:id="@+id/countdownOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/usesense_overlay_light"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Countdown number circle -->
            <FrameLayout
                android:id="@+id/countdownCircle"
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:background="@drawable/usesense_countdown_circle"
                android:elevation="16dp">

                <TextView
                    android:id="@+id/countdownNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="@color/usesense_indigo_600"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black" />
            </FrameLayout>

            <!-- "Get ready..." sub-label -->
            <TextView
                android:id="@+id/countdownLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:background="@drawable/usesense_pill_bg"
                android:text="@string/usesense_countdown_label"
                android:textColor="@color/usesense_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <!-- Instructions Screen -->
    <LinearLayout
        android:id="@+id/instructionsLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="@color/usesense_background"
        android:visibility="gone">

        <TextView
            android:id="@+id/instructionsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/usesense_title"
            android:textColor="@color/usesense_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/instructionsBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="@color/usesense_text_secondary"
            android:textSize="16sp"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:text="@string/usesense_start_button"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/usesense_indigo_600" />
    </LinearLayout>

    <!-- Processing / Loading Screen -->
    <LinearLayout
        android:id="@+id/processingLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="@color/usesense_background"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/processingSpinner"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="@color/usesense_indigo_500" />

        <TextView
            android:id="@+id/processingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/usesense_uploading"
            android:textColor="@color/usesense_text_primary"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Result Screen -->
    <LinearLayout
        android:id="@+id/resultLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="@color/usesense_background"
        android:visibility="gone">

        <TextView
            android:id="@+id/resultIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:gravity="center"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/resultText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="@color/usesense_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/resultDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/usesense_text_secondary"
            android:textSize="14sp"
            android:textAlignment="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/doneButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:text="@string/usesense_done"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/usesense_indigo_600" />
    </LinearLayout>

    <!-- Cancel button (floating) -->
    <ImageButton
        android:id="@+id/cancelButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/usesense_cancel"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="@color/usesense_text_primary"
        android:elevation="4dp" />

</FrameLayout>
